  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "4.1.4",
    "@types/node": "22.15.21",
    "@types/pg": "8.15.4",
    "@vitejs/plugin-vue": "5.2.1",
    "pg": "8.16.0",
    "tailwindcss": "4.1.4",
    "tsx": "^4.19.4",
    "typescript": "5.8.3",
    "vite": "6.4.2",
    "vue-tsc": "2.2.8"
