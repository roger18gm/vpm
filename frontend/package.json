    "test:e2e:stop-servers": "tsx ./tests/e2e/stop-e2e-servers-runner.ts",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --workers=1"
  },
  "dependencies": {
    "@fontsource/inter": "5.2.5",
